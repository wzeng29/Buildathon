# ====================
# API CONFIGURATION
# ====================
# Port where the API will run
PORT=3001

# ====================
# DATABASE CONFIGURATION
# ====================
# PostgreSQL connection settings
DB_HOST=postgres
DB_PORT=5432
DB_NAME=usersdb
DB_USER=postgres
DB_PASSWORD=postgres

# ====================
# OPENTELEMETRY CONFIGURATION
# ====================
# Service name that appears in traces
OTEL_SERVICE_NAME=users-api-microservice

# Tempo endpoint for receiving traces
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318

# Protocol for exporting traces
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Exporters configuration
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none

# ====================
# OBSERVABILITY SETTINGS
# ====================
# Trace sampling rate (0.1 = 10%, 1.0 = 100%)
# Lower values reduce storage costs but may miss some requests
TRACE_SAMPLING_RATE=1.0

# Service version for resource attributes
SERVICE_VERSION=1.0.0

# ====================
# ENVIRONMENT
# ====================
# Deployment environment (development, staging, production)
NODE_ENV=development

# ====================
# LOGGING
# ====================
# Log level (debug, info, warn, error, fatal)
LOG_LEVEL=info

# ====================
# AUTHENTICATION
# ====================
# JWT secret key for signing tokens
# IMPORTANT: Change this to a strong random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production

# JWT token expiration time (examples: 1h, 24h, 7d, 30d)
JWT_EXPIRATION=24h

# API Key for alternative authentication method
# Used with x-api-key header
API_KEY=your-api-key-change-in-production
