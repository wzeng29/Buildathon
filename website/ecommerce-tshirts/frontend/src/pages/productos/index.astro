---
import StoreLayout from "@/layouts/StoreLayout.astro";
import ProductGrid from "@/components/store/ProductGrid";
---

<StoreLayout title="Products" description="Browse our full t-shirt collection" lang="en">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">T-Shirt Catalog</h1>
      <p class="text-gray-500 mt-1">Find your perfect tee from our premium selection</p>
    </div>
    <ProductGrid client:load />
  </div>
</StoreLayout>
