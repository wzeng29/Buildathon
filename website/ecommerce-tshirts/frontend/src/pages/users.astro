---
import Base from "@/layouts/Base.astro";
import UsersTable from "@/components/UsersTable";
---

<Base title="Users Management - Users API">
  <section class="section pt-14">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <h1 class="mb-4 text-h3 lg:text-h1">Users Management</h1>
          <p class="mb-8 text-lg">
            Create, view, and manage users with full CRUD operations. All changes are immediately reflected in the PostgreSQL database.
          </p>
          <UsersTable client:load />
        </div>
      </div>
    </div>
  </section>
</Base>
