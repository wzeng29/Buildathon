---
import StoreLayout from "@/layouts/StoreLayout.astro";
---

<StoreLayout title="Página no encontrada">
  <section class="flex flex-col items-center justify-center py-32 px-4 text-center">
    <h1 class="text-8xl font-bold text-indigo-600 mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-gray-800 mb-3">Página no encontrada</h2>
    <p class="text-gray-500 mb-8 max-w-md">
      La página que buscas no existe o fue eliminada.
    </p>
    <a href="/" class="bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors">
      Volver al inicio
    </a>
  </section>
</StoreLayout>
