---
import StoreLayout from "@/layouts/StoreLayout.astro";
import MyOrders from "@/components/store/MyOrders";
---

<StoreLayout title="My orders" description="Your purchase history" lang="en">
  <div class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-gray-900">My Orders</h1>
      <a href="/productos" class="text-indigo-600 text-sm font-medium hover:underline">
        Continue shopping →
      </a>
    </div>
    <MyOrders client:load />
  </div>
</StoreLayout>
