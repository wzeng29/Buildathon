    { "type": "row", "title": "💰 Error Budget — Presupuesto de Errores Restante", "id": 2, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 }, "collapsed": false },

    {
      "id": 20, "type": "gauge",
      "title": "Availability Error Budget Restante",
      "description": "Budget disponible para el período actual. SLO 99.9% = 43.8 min/mes de downtime permitido. Si llega a 0%, cualquier error adicional viola el SLO.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 7 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "minVizHeight": 75,
        "minVizWidth": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 25 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "clamp_min(slo:availability:error_budget_remaining * 100, 0)",
        "legendFormat": "Availability Budget",
        "refId": "A"
      }]
    },

    {
      "id": 21, "type": "gauge",
      "title": "Latency Error Budget Restante",
      "description": "Budget para latencia. SLO 95% = 5% de requests pueden superar 500ms. Si se agota, el equipo debería congelar despliegues.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 7 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 25 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "clamp_min(slo:latency:error_budget_remaining * 100, 0)",
        "legendFormat": "Latency Budget",
        "refId": "A"
      }]
    },

    {
      "id": 22, "type": "timeseries",
      "title": "Error Budget — Histórico (ventana actual)",
      "description": "Evolución del error budget disponible. Una tendencia descendente rápida indica un problema activo. Si cualquier línea llega a 0% se viola el SLO.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "min"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line", "lineInterpolation": "smooth", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 0 }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Availability Budget" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }] },
          { "matcher": { "id": "byName", "options": "Latency Budget" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "clamp_min(slo:availability:error_budget_remaining * 100, 0)", "legendFormat": "Availability Budget", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "clamp_min(slo:latency:error_budget_remaining * 100, 0)", "legendFormat": "Latency Budget", "refId": "B" }
      ]
    },

    { "type": "row", "title": "🔥 Burn Rate — Velocidad de Consumo del Budget", "id": 3, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "collapsed": false },

    {
      "id": 30, "type": "stat",
      "title": "Availability Burn Rate (1h)",
      "description": "1x = consumo normal (no hay problema). 14.4x = el budget mensual se agota en 2 horas → alerta crítica. > 1x y < 14.4x = degradación, investigar.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 16 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          },
          "custom": { "displayMode": "auto" }
        },
        "overrides": [{ "matcher": { "id": "byName", "options": "Availability Burn Rate" }, "properties": [{ "id": "displayName", "value": "Availability Burn Rate" }] }]
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "slo:availability:burn_rate_1h",
        "legendFormat": "Availability Burn Rate",
        "refId": "A"
      }]
    },

    {
      "id": 31, "type": "stat",
      "title": "Latency Burn Rate (1h)",
      "description": "Mide si estamos consumiendo el error budget de latencia más rápido de lo esperado. 14.4x = critical.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 16 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
