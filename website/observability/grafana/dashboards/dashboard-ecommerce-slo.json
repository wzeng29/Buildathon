          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 14.4 }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Availability Burn Rate" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }] },
          { "matcher": { "id": "byName", "options": "Latency Burn Rate" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }] },
          { "matcher": { "id": "byName", "options": "Umbral Crítico (14.4x)" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [8, 4] } }, { "id": "custom.lineWidth", "value": 2 }] }
        ]
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "slo:availability:burn_rate_1h", "legendFormat": "Availability Burn Rate", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "slo:latency:burn_rate_1h", "legendFormat": "Latency Burn Rate", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vector(14.4)", "legendFormat": "Umbral Crítico (14.4x)", "refId": "C" }
      ]
    },

