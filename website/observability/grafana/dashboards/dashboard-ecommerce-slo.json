{
  "title": "Poleras Store · SLO — Error Budget & Burn Rate",
  "uid": "ecommerce-slo-v1",
  "description": "Service Level Objectives para Poleras Store. Muestra cumplimiento SLO, error budget restante y burn rate. Si el burn rate supera 14.4x, el budget mensual se agota en menos de 2 horas.",
  "tags": ["ecommerce", "slo", "error-budget", "production"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "links": [
    { "title": "RED Metrics", "url": "/d/ecommerce-apm-v1", "type": "link", "icon": "external link", "tooltip": "Rate / Errors / Duration", "keepTime": true, "targetBlank": false },
    { "title": "Logs", "url": "/d/ecommerce-logs-v1", "type": "link", "icon": "external link", "tooltip": "Error Streams y User Journey", "keepTime": true, "targetBlank": false },
    { "title": "Distributed Tracing", "url": "/d/ecommerce-traces-v1", "type": "link", "icon": "external link", "tooltip": "Service Map y trazas end-to-end", "keepTime": true, "targetBlank": false }
  ],
  "panels": [

    { "type": "row", "title": "🎯 SLO Status — Cumplimiento Actual", "id": 1, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },

    {
      "id": 10, "type": "stat",
      "title": "Availability SLI",
      "description": "SLO target: 99.9% de requests exitosos (non-5xx). Umbral de alerta: < 99.9%",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 98,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sli:availability:ratio_rate5m * 100",
        "legendFormat": "Availability",
        "refId": "A"
      }]
    },

    {
      "id": 11, "type": "stat",
      "title": "Latency SLI (% requests < 500ms)",
      "description": "SLO target: 95% de requests bajo 500ms. Umbral de alerta: < 95%",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 80,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 93 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sli:latency:ratio_rate5m * 100",
        "legendFormat": "Latency SLI",
        "refId": "A"
      }]
    },

    {
      "id": 12, "type": "stat",
      "title": "Database SLI",
      "description": "SLO target: 99.9% de queries exitosas. Umbral de alerta: < 99.9%",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 3,
          "min": 98,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sli:database:success_ratio_rate5m * 100",
