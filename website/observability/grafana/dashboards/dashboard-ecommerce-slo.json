        "refId": "A"
      }]
    },

    {
      "id": 32, "type": "timeseries",
      "title": "Burn Rate — Histórico (línea crítica: 14.4x)",
      "description": "Si el burn rate cruza la línea roja de 14.4x, el budget mensual completo se agotará en menos de 2 horas.",
